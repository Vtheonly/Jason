    "candidate_name": { "type": "string" },
    "supervisor_name": { "type": "string" },
    "degree_program": { "type": "string" },
    "academic_year": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "summary": { "type": "string" }
